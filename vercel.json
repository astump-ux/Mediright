{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/demos",
      "dest": "/demos.html"
    },
    {
      "src": "/analyse",
      "dest": "/mediright_analyse_demo.html"
    },
    {
      "src": "/dashboard",
      "dest": "/mediright_dashboard.html"
    },
    {
      "src": "/(.*\\.html)",
      "dest": "/$1"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
